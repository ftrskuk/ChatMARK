{
  "name": "chatmark-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "ChatMARK - Bookmark tabs for AI chat conversations",
  "scripts": {
    "build": "esbuild src/content.js --bundle --outfile=dist/content.js --format=iife --target=chrome110",
    "build:css": "cp src/content.css dist/content.css",
    "build:fonts": "mkdir -p dist/fonts && cp src/fonts/*.woff2 dist/fonts/",
    "build:manifest": "cp src/manifest.json dist/manifest.json",
    "build:icons": "mkdir -p dist/icons && cp src/icons/* dist/icons/",
    "build:all": "mkdir -p dist && npm run build && npm run build:css && npm run build:fonts && npm run build:icons && npm run build:manifest",
    "watch": "esbuild src/content.js --bundle --outfile=dist/content.js --format=iife --target=chrome110 --watch",
    "dev": "npm run build:all && npm run watch",
    "lint": "eslint eslint.config.js \"src/**/*.js\" \"test/**/*.js\"",
    "format": "prettier --write \"**/*.js\" \"**/*.ts\" \"**/*.json\" \"**/*.css\" \"**/*.md\" \"**/*.yml\" \"!dist/**\" \"!node_modules/**\"",
    "format:check": "prettier --check \"**/*.js\" \"**/*.ts\" \"**/*.json\" \"**/*.css\" \"**/*.md\" \"**/*.yml\" \"!dist/**\" \"!node_modules/**\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "tsx --test \"test/*.test.js\" \"test/*.test.ts\"",
    "test:stability": "tsx test/storage-key-stability.js",
    "test": "npm run test:unit && npm run test:stability",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build:all"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.21.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
