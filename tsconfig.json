{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "src/constants.js",
    "src/rail/*.js",
    "src/state.js",
    "src/storage.js",
    "src/text.js",
    "test/*.js",
    "types/**/*.d.ts"
  ]
}
